<Window x:Class="HdLabs.Memo.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HdLabs.Memo"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Icon="pack://application:,,,/HdLabs.Common;component/Assets/hd_icon_green.png"
        Height="760"
        Width="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 디자이너가 App.xaml 머지를 읽지 못해도 MainWindow에서 스타일을 찾을 수 있게 -->
                <ResourceDictionary Source="pack://application:,,,/HdLabs.Memo;component/Themes/MemoUiChrome.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- 포레스트 민트 + 웜 페이퍼: 그라데이션으로 깊이만 살짝 -->
            <LinearGradientBrush x:Key="MemoBarBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#E2F0EA" Offset="0"/>
                <GradientStop Color="#B8D4C8" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MemoBodyBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FEFFFE" Offset="0"/>
                <GradientStop Color="#F2F7F5" Offset="0.55"/>
                <GradientStop Color="#E8F1ED" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MemoFooterBrush" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#C9E0D6" Offset="0"/>
                <GradientStop Color="#9CBEAE" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="MemoOuterBorderBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#D9EDE4" Offset="0"/>
                <GradientStop Color="#9BB5AA" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="MemoSectionDividerBrush" Color="#3A5248"/>
            <SolidColorBrush x:Key="MemoToolbarIconBrush" Color="#2D4A40"/>
            <SolidColorBrush x:Key="MemoTextBrush" Color="#263330"/>
            <SolidColorBrush x:Key="MemoSliderTrackBrush" Color="#6E9084"/>
            <SolidColorBrush x:Key="MemoSliderThumbStrokeBrush" Color="#C5DDD3"/>
            <SolidColorBrush x:Key="MemoHoverWashBrush" Color="#26FFFFFF"/>
            <!-- 떠 있는 메뉴/팝업: 본문 카드와 톤 맞춤, 완전 불투명 -->
            <SolidColorBrush x:Key="MemoFlyoutPanelBrush" Color="#F0F6F2"/>
            <SolidColorBrush x:Key="MemoFlyoutPanelBorderBrush" Color="#7BA896"/>

            <Style x:Key="MemoIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HoverBg"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverBg" Property="Background" Value="{StaticResource MemoHoverWashBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="HoverBg" Property="Background" Value="#40FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        <Style x:Key="MemoFormatTextButton" TargetType="Button" BasedOn="{StaticResource MemoIconButton}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontStyle" Value="Normal"/>
        </Style>

        <!-- 팝업/리스트: 내용을 왼쪽으로 (MemoIconButton 템플릿이 Center 고정이라 별도 템플릿) -->
        <Style x:Key="MemoPopupListButton" TargetType="Button" BasedOn="{StaticResource MemoFormatTextButton}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HoverBg"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBg" Property="Background" Value="{StaticResource MemoHoverWashBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverBg" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 푸터 콤보: 민트·포레스트 톤과 맞는 반투명 -->
        <Style x:Key="MemoFooterCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#55FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource MemoOuterBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
            <Setter Property="MinHeight" Value="26"/>
            <!-- 하단 툴바: 드롭다운이 본문·카드 밖으로 길게 나가지 않게 높이 제한 -->
            <Setter Property="MaxDropDownHeight" Value="220"/>
                <Setter Property="Padding" Value="5,2"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="12.5"/>
            </Style>
            <Style x:Key="MemoFooterComboEditable" TargetType="ComboBox" BasedOn="{StaticResource MemoFooterCombo}">
                <Setter Property="IsEditable" Value="True"/>
                <Setter Property="StaysOpenOnEdit" Value="True"/>
            </Style>

            <Style x:Key="MemoSliderInvisibleRepeat" TargetType="RepeatButton">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Rectangle Fill="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- 참고: 갈회색 트랙 + 흰 원 썸(얇은 테두리) + 아래쪽 가벼운 그림자 -->
            <Style x:Key="MemoFooterSlider" TargetType="Slider">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="TickPlacement" Value="None"/>
                <Setter Property="IsSnapToTickEnabled" Value="False"/>
                <!-- 트랙 클릭 시 커서 위치로 썸 이동 (기본 LargeChange 점프 방지) -->
                <Setter Property="IsMoveToPointEnabled" Value="True"/>
                <Setter Property="Minimum" Value="0.35"/>
                <Setter Property="Maximum" Value="1"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Foreground" Value="{StaticResource MemoSliderTrackBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid SnapsToDevicePixels="True" MinHeight="24">
                                <Rectangle Height="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Stretch"
                                       Margin="12,0,12,0"
                                       Fill="{StaticResource MemoSliderTrackBrush}"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Opacity="0.92"/>
                                <Track x:Name="PART_Track" VerticalAlignment="Center">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Style="{StaticResource MemoSliderInvisibleRepeat}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Style="{StaticResource MemoSliderInvisibleRepeat}"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="24" Height="24">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid Width="24" Height="24">
                                                        <Ellipse Width="14"
                                                             Height="14"
                                                             Fill="#FFFFFF"
                                                             Stroke="{StaticResource MemoSliderThumbStrokeBrush}"
                                                             StrokeThickness="0.9"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect BlurRadius="4"
                                                                              ShadowDepth="2"
                                                                              Direction="270"
                                                                              Opacity="0.28"
                                                                              Color="#40000000"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <!-- 참고 UI 구성: 스티키 카드 하나 = [상단바 | 본문 | 하단 툴바] 세로 스택만 -->
    <Border Padding="24"
            Background="Transparent"
            MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
        <Border x:Name="RootMemoCard"
                CornerRadius="16"
                BorderBrush="{StaticResource MemoOuterBorderBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True"
                ClipToBounds="True"
                Background="{StaticResource MemoBodyBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="36"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Opacity="0.19"
                                  Color="#40000000"/>
            </Border.Effect>

            <Grid>
                <!-- 비율 고정감: 상·하단은 내용 높이, 가운데만 남는 공간 전부 -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="464*"/>
                    <RowDefinition Height="24*"/>
                    <RowDefinition Height="11*"/>
                    <RowDefinition Height="93*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══ (1) 상단바: 왼쪽 '+만' · 가운데 빈 여백 · 오른쪽 아이콘 묶음 ═══ -->
                <Border Grid.Row="0"
                        MinHeight="48"
                        Background="{StaticResource MemoBarBrush}"
                        CornerRadius="16,16,0,0"
                        Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Style="{StaticResource MemoIconButton}"
                                ToolTip="새 메모 (Ctrl+N)"
                                Command="{Binding NewCommand}"
                                Padding="8,8" Click="Button_Click">
                            <Viewbox Width="26"
                                     Height="26"
                                     Stretch="Uniform">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="24"
                                           Foreground="{StaticResource MemoToolbarIconBrush}"
                                           Text="&#xE710;" RenderTransformOrigin="0.542,0.542"/>
                            </Viewbox>
                        </Button>

                        <!-- 가운데는 의도적으로 비움 (참고 스크린과 동일) -->

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="AI 비서"
                                    Padding="8,8"
                                    Click="AiAssistant_Click">
                                <Border CornerRadius="8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#559BB5AA"
                                        BorderThickness="1"
                                        Padding="8,4">
                                    <TextBlock Text="AI"
                                               FontFamily="Segoe UI"
                                               FontWeight="SemiBold"
                                               FontSize="14.5"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"/>
                                </Border>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="더보기"
                                    Padding="8,8"
                                    Click="MoreOptions_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE712;"/>
                                </Viewbox>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="저장" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S"/>
                                        <Separator/>
                                        <MenuItem Header="메모 편집" Command="{Binding ShowEditorCommand}"/>
                                        <MenuItem Header="메모 목록" Command="{Binding ShowListCommand}"/>
                                        <Separator/>
                                        <MenuItem Header="현재 메모 삭제" Click="DeleteCurrentMemo_Click"/>
                                        <Separator/>
                                        <MenuItem Header="숨기기 (트레이로)" Click="HideToTray_Click" InputGestureText="Esc"/>
                                        <MenuItem Header="앞으로 가져오기 단축키 설정..." Click="HotkeySetup_Click"/>
                                        <MenuItem Header="완전 종료" Click="ExitApp_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="캘린더 — 이 메모에 날짜 붙이기, Windows 캘린더 열기"
                                    Padding="8,8"
                                    Click="CalendarButton_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE787;"/>
                                </Viewbox>
                            </Button>

                            <Button Style="{StaticResource MemoIconButton}"
                                    Padding="8,8"
                                    ClipToBounds="False"
                                    ToolTip="알림 — 이 메모에 미리 알림 시각 설정"
                                    Click="AlarmButton_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <Canvas Width="26"
                                            Height="26"
                                            ClipToBounds="False"
                                            SnapsToDevicePixels="True">
                                        <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 6,7.5 Q 10,2.25 13,7.5"/>
                                        <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 13,7.5 Q 17,2.25 20,7.5"/>
                                        <Ellipse Canvas.Left="5.5"
                                                 Canvas.Top="7.5"
                                                 Width="15"
                                                 Height="15"
                                                 Stroke="{StaticResource MemoToolbarIconBrush}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent"/>
                                        <Line X1="13"
                                              Y1="15"
                                              X2="18.5"
                                              Y2="15"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Line X1="13"
                                              Y1="15"
                                              X2="13"
                                              Y2="9"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Line X1="10.5"
                                              Y1="21.5"
                                              X2="8"
                                              Y2="23.5"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"/>
                                        <Line X1="15.5"
                                              Y1="21.5"
                                              X2="18"
                                              Y2="23.5"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button x:Name="ColorPickerButton"
                                    Style="{StaticResource MemoIconButton}"
                                    ToolTip="메모지 색 (본문 틴트)"
                                    Padding="8,8"
                                    Click="ColorPickerButton_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE790;"/>
                                </Viewbox>
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ColorTintMenu">
                                        <MenuItem Click="ColorTintClick" Tag="#E8F1ED" Header="기본 민트"/>
                                        <MenuItem Click="ColorTintClick" Tag="#E8EEF1" Header="아이스 블루"/>
                                        <MenuItem Click="ColorTintClick" Tag="#F0EDE8" Header="웜 페이퍼"/>
                                        <MenuItem Click="ColorTintClick" Tag="#EEF0E6" Header="올리브 미스트"/>
                                        <MenuItem Click="ColorTintClick" Tag="#F1EBF0" Header="소프트 라벤더"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="항상 위"
                                    Padding="8,8"
                                    Command="{Binding TogglePinCommand}">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="24"
                                               Foreground="{StaticResource MemoToolbarIconBrush}"
                                               Text="&#xE718;"/>
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource MemoIconButton}"
                                    ToolTip="닫기"
                                    Padding="8,8"
                                    Click="Close_Click">
                                <Viewbox Width="26"
                                         Height="26"
                                         Stretch="Uniform"
                                         SnapsToDevicePixels="True">
                                    <Canvas Width="26"
                                            Height="26"
                                            SnapsToDevicePixels="True">
                                        <Line X1="7"
                                              Y1="7"
                                              X2="19"
                                              Y2="19"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1.15"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Line X1="19"
                                              Y1="7"
                                              X2="7"
                                              Y2="19"
                                              Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1.15"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="1"
                           Height="1"
                           Fill="{StaticResource MemoSectionDividerBrush}"
                           SnapsToDevicePixels="True"/>

                <!-- ═══ (2) 본문: 한 장의 노트처럼 한 덩어리 입력 영역 ═══ -->
                <Border Grid.Row="2"
                        Background="Transparent" Grid.RowSpan="4">
                    <Grid Margin="22,16,22,16">

                        <!-- 편집: 제목(첫 줄) + 본문 = 시각적으로 한 블록 (참고: 상단 한 줄 제목 느낌) -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditorView}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <RichTextBox x:Name="MemoTitle"
                                     Grid.Row="0"
                                     AcceptsReturn="False"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Hidden"
                                     IsDocumentEnabled="True"
                                     GotKeyboardFocus="MemoTitle_GotKeyboardFocus"
                                     TextChanged="MemoTitle_TextChanged"
                                     PreviewKeyDown="MemoTitle_PreviewKeyDown"
                                     Style="{StaticResource MemoTitleRichTextBox}"/>

                            <RichTextBox x:Name="MemoBody"
                                         Grid.Row="1"
                                         AcceptsReturn="True"
                                         AllowDrop="True"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         FontFamily="Malgun Gothic"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="15"
                                         Padding="0"
                                         IsDocumentEnabled="True"
                                         Foreground="{StaticResource MemoTextBrush}"
                                         GotKeyboardFocus="MemoBody_GotKeyboardFocus"
                                         TextChanged="MemoBody_TextChanged"
                                         SelectionChanged="MemoBody_SelectionChanged"
                                         PreviewDragOver="MemoBody_PreviewDragOver"
                                         Drop="MemoBody_Drop"
                                         MouseUp="MemoBody_FontContext_MouseUp"
                                         KeyUp="MemoBody_FontContext_KeyUp"
                                         Loaded="MemoBody_Loaded">
                                <RichTextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="잘라내기" InputGestureText="Ctrl+X" Click="MemoBodyContext_Cut_Click"/>
                                        <MenuItem Header="복사" InputGestureText="Ctrl+C" Click="MemoBodyContext_Copy_Click"/>
                                        <MenuItem Header="붙여넣기" InputGestureText="Ctrl+V" Click="MemoBodyContext_Paste_Click"/>
                                        <Separator/>
                                        <MenuItem Header="굵게"
                                                  InputGestureText="Ctrl+B"
                                                  Click="FormatBold_Click"/>
                                        <MenuItem Header="기울임" Click="FormatItalic_Click"/>
                                        <MenuItem Header="밑줄" Click="FormatUnderline_Click"/>
                                        <MenuItem Header="취소선" Click="FormatStrike_Click"/>
                                        <Separator/>
                                        <MenuItem Header="자주 쓰는 글꼴">
                                            <MenuItem Header="맑은 고딕" FontFamily="Malgun Gothic" Click="MemoBodyContext_FontFamily_Click" Tag="Malgun Gothic"/>
                                            <MenuItem Header="돋움" FontFamily="Dotum" Click="MemoBodyContext_FontFamily_Click" Tag="Dotum"/>
                                            <MenuItem Header="굴림" FontFamily="Gulim" Click="MemoBodyContext_FontFamily_Click" Tag="Gulim"/>
                                            <MenuItem Header="Consolas" FontFamily="Consolas" Click="MemoBodyContext_FontFamily_Click" Tag="Consolas"/>
                                            <MenuItem Header="Times New Roman" FontFamily="Times New Roman" Click="MemoBodyContext_FontFamily_Click" Tag="Times New Roman"/>
                                            <MenuItem Header="Arial" FontFamily="Arial" Click="MemoBodyContext_FontFamily_Click" Tag="Arial"/>
                                            <MenuItem Header="Segoe UI" FontFamily="Segoe UI" Click="MemoBodyContext_FontFamily_Click" Tag="Segoe UI"/>
                                        </MenuItem>
                                        <MenuItem Header="크기(프리셋) — 하단 단위·숫자와 같음">
                                            <MenuItem Header="8" Click="MemoBodyContext_FontSizePreset_Click" Tag="8"/>
                                            <MenuItem Header="9" Click="MemoBodyContext_FontSizePreset_Click" Tag="9"/>
                                            <MenuItem Header="10" Click="MemoBodyContext_FontSizePreset_Click" Tag="10"/>
                                            <MenuItem Header="12" Click="MemoBodyContext_FontSizePreset_Click" Tag="12"/>
                                            <MenuItem Header="14" Click="MemoBodyContext_FontSizePreset_Click" Tag="14"/>
                                            <MenuItem Header="15" Click="MemoBodyContext_FontSizePreset_Click" Tag="15"/>
                                            <MenuItem Header="16" Click="MemoBodyContext_FontSizePreset_Click" Tag="16"/>
                                            <MenuItem Header="18" Click="MemoBodyContext_FontSizePreset_Click" Tag="18"/>
                                            <MenuItem Header="20" Click="MemoBodyContext_FontSizePreset_Click" Tag="20"/>
                                            <MenuItem Header="24" Click="MemoBodyContext_FontSizePreset_Click" Tag="24"/>
                                            <MenuItem Header="32" Click="MemoBodyContext_FontSizePreset_Click" Tag="32"/>
                                        </MenuItem>
                                        <MenuItem Header="크기 +1" Click="MemoBodyContext_FontSizeStep_Click" Tag="1"
                                                  ToolTip="선택(또는 커서) 글자에 대해, 현재 단위에서 한 단계 큼"/>
                                        <MenuItem Header="크기 -1" Click="MemoBodyContext_FontSizeStep_Click" Tag="-1"
                                                  ToolTip="선택(또는 커서) 글자에 대해, 현재 단위에서 한 단계 작게"/>
                                        <Separator/>
                                        <MenuItem Header="크기 단위(표기) — 하단 콤보와 동기화" IsEnabled="False"
                                                  ToolTip="아래 ‘포인트’ 또는 ‘px’를 고르면 하단 바의 pt/px 콤보박스가 같이 바뀝니다."/>
                                        <MenuItem Header="포인트 (pt)" Click="MemoBodyContext_FontSizeUnitPt_Click"
                                                  ToolTip="WPF는 내부 DIP(1/96)로 저장, 숫자는 인쇄 pt(1/72in)로 표기합니다."/>
                                        <MenuItem Header="px (논리·레이아웃 픽셀)" Click="MemoBodyContext_FontSizeUnitPx_Click"
                                                  ToolTip="WPF TextElement.FontSize와 같은 단위(디바이스 독립)입니다."/>
                                    </ContextMenu>
                                </RichTextBox.ContextMenu>
                            </RichTextBox>
                        </Grid>

                        <!-- 목록: 같은 카드 안에서만 중앙 패널 교체 -->
                        <DockPanel LastChildFill="True">
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsListView}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                            <DockPanel DockPanel.Dock="Top" LastChildFill="True" Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource MemoTextBrush}"
                                        Padding="12,6"
                                        Background="#33FFFFFF"
                                        BorderBrush="{StaticResource MemoOuterBorderBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Content="열기"
                                        Command="{Binding OpenSelectedCommand}"
                                        Margin="8,0,0,0"/>

                                <TextBlock Text="메모 목록"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource MemoTextBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <ListView x:Name="MemoList"
                                      Style="{StaticResource MemoListView}"
                                      ItemsSource="{Binding Items}"
                                      SelectedItem="{Binding Selected}"
                                      SelectionMode="Extended"
                                      MouseDoubleClick="MemoList_OnMouseDoubleClick"
                                      KeyDown="MemoList_OnKeyDown">
                                <ListView.ContextMenu>
                                    <ContextMenu DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}">
                                        <MenuItem Header="편집" Command="{Binding OpenSelectedCommand}"/>
                                        <MenuItem Header="삭제" Click="MemoList_DeleteSelected_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>

                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="6,8"/>
                                        <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#55FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="제목" Width="320" DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="생성" Width="150" DisplayMemberBinding="{Binding CreatedDisplay}"/>
                                        <GridViewColumn Header="수정" Width="150" DisplayMemberBinding="{Binding ModifiedDisplay}"/>
                                        <GridViewColumn Header="그룹" Width="120" DisplayMemberBinding="{Binding Group}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </Grid>
                </Border>

                <Rectangle Grid.Row="6"
                           Height="1"
                           Fill="{StaticResource MemoSectionDividerBrush}"
                           SnapsToDevicePixels="True"/>

                <!-- ═══ (3) 하단: 글꼴·크기(왼쪽) + 서식 + 불투명도 ═══ -->
                <Border Grid.Row="7"
                        MinHeight="54"
                        CornerRadius="0,0,16,16"
                        Background="{StaticResource MemoFooterBrush}"
                        ClipToBounds="True">
                        <Grid Margin="10,6,8,6">
                        <Grid.ColumnDefinitions>
                            <!-- 폰트/크기 + 서식 + 맞춤(3) + … ; 남는 폭은 * -->
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <!-- 남는 공간을 먹는 스페이서 -->
                            <ColumnDefinition Width="*"/>
                            <!-- 투명도 슬라이더는 길이 고정 -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="FontFamilyPicker"
                                  Grid.Column="0"
                                  Width="150"
                                  VerticalAlignment="Center"
                                  Margin="10,0,4,0"
                                  Style="{StaticResource MemoFooterComboEditable}"
                                  ToolTip="글꼴: 목록에서 고르거나 이름을 직접 입력 후 Enter(탭으로 적용)"
                                  SelectionChanged="FontFamilyPicker_SelectionChanged"
                                  DropDownOpened="FontFamilyPicker_DropDownOpened"
                                  DropDownClosed="FontFamilyPicker_DropDownClosed"
                                  LostKeyboardFocus="FontFamilyPicker_LostKeyboardFocus"
                                  PreviewKeyDown="FontFamilyPicker_PreviewKeyDown">
                            <!-- ComboBox 내부 편집 TextBox가 기본 TextBox 스타일을 끌고 와서 텍스트가 안 보이는 경우 방지 -->
                            <ComboBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Path=Source}" FontFamily="{Binding}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox x:Name="FontSizePicker"
                                  Grid.Column="1"
                                  Width="74"
                                  VerticalAlignment="Center"
                                  Margin="0,0,3,0"
                                  Style="{StaticResource MemoFooterComboEditable}"
                                  ToolTip="크기: 숫자 + 단위(오른쪽). pt=포인트(1/72), px=기기독립 픽셀(1/96) — WPF FontSize"
                                  SelectionChanged="FontSizePicker_SelectionChanged"
                                  DropDownOpened="FooterCombo_DropDownOpened"
                                  LostKeyboardFocus="FontSizePicker_LostKeyboardFocus"
                                  PreviewKeyDown="FontSizePicker_PreviewKeyDown">
                            <ComboBox.Resources>
                                <Style TargetType="{x:Type TextBox}">
                                    <Setter Property="Foreground" Value="{StaticResource MemoTextBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ComboBox.Resources>
                        </ComboBox>
                        <ComboBox x:Name="FontSizeUnitPicker"
                                  Grid.Column="2"
                                  Width="40"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"
                                  Style="{StaticResource MemoFooterCombo}"
                                  ToolTip="pt(포인트) / px(레이아웃·논리 픽셀, WPF DIP와 동일)"
                                  SelectionChanged="FontSizeUnitPicker_SelectionChanged"
                                  DropDownOpened="FooterCombo_DropDownOpened"/>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="3"
                                Margin="2,0,0,0"
                                FontWeight="Bold"
                                Foreground="{StaticResource MemoToolbarIconBrush}"
                                Content="B"
                                HorizontalAlignment="Center"
                                ToolTip="굵게"
                                Click="FormatBold_Click"/>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="4"
                                Margin="2,0,0,0"
                                FontStyle="Italic"
                                Foreground="{StaticResource MemoToolbarIconBrush}"
                                Content="/"
                                HorizontalAlignment="Center"
                                ToolTip="기울임"
                                Click="FormatItalic_Click"/>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="5"
                                Margin="2,0,0,0"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource MemoToolbarIconBrush}"
                                ToolTip="밑줄"
                                Click="FormatUnderline_Click">
                            <TextBlock FontFamily="Segoe UI"
                                           FontSize="17"
                                           Foreground="{StaticResource MemoToolbarIconBrush}"
                                           Text="U"
                                           TextDecorations="Underline"/>
                        </Button>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="6"
                                Margin="2,0,0,0"
                                HorizontalAlignment="Center"
                                ToolTip="취소선"
                                Click="FormatStrike_Click">
                            <TextBlock Text="T"
                                           FontFamily="Segoe UI"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource MemoToolbarIconBrush}"
                                           TextDecorations="Strikethrough"/>
                        </Button>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="7"
                                Margin="4,0,0,0"
                                HorizontalAlignment="Center"
                                ToolTip="왼쪽 맞춤(문단)"
                                Click="FormatAlignLeft_Click">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Canvas Width="20" Height="20" SnapsToDevicePixels="True">
                                    <Path Stroke="{StaticResource MemoToolbarIconBrush}" StrokeThickness="1.1"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 2.5,5.5 h 6 M 2.5,10 h 8 M 2.5,14.5 h 4"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="8"
                                Margin="2,0,0,0"
                                HorizontalAlignment="Center"
                                ToolTip="가운데 맞춤(문단)"
                                Click="FormatAlignCenter_Click">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Canvas Width="20" Height="20" SnapsToDevicePixels="True">
                                    <Path Stroke="{StaticResource MemoToolbarIconBrush}" StrokeThickness="1.1"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 5,5.5 h 10 M 3.5,10 h 13 M 5.5,14.5 h 9"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource MemoFormatTextButton}"
                                Grid.Column="9"
                                Margin="2,0,0,0"
                                HorizontalAlignment="Center"
                                ToolTip="오른쪽 맞춤(문단)"
                                Click="FormatAlignRight_Click">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Canvas Width="20" Height="20" SnapsToDevicePixels="True">
                                    <Path Stroke="{StaticResource MemoToolbarIconBrush}" StrokeThickness="1.1"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 11.5,5.5 h 6 M 9,10 h 8.5 M 13.5,14.5 h 4"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource MemoIconButton}"
                                Grid.Column="10"
                                Margin="4,0,0,0"
                                HorizontalAlignment="Center"
                                ToolTip="체크리스트 — 체크박스를 직접 누를 수 있어요 (문단 끝에 한 줄)"
                                Foreground="{StaticResource MemoToolbarIconBrush}"
                                Click="InsertChecklistLine_Click">
                            <Viewbox Width="22"
                                         Height="22"
                                         Stretch="Uniform">
                                <Canvas Width="20"
                                            Height="20"
                                            SnapsToDevicePixels="True">
                                    <Rectangle Canvas.Left="2"
                                                   Canvas.Top="2"
                                                   Width="16"
                                                   Height="16"
                                                   RadiusX="3"
                                                   RadiusY="3"
                                                   Stroke="{StaticResource MemoToolbarIconBrush}"
                                                   StrokeThickness="1"
                                                   Fill="Transparent"/>
                                    <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1.25"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 6.5,10.5 L 9,13 L 13.5,7"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Grid Grid.Column="11"
                              Margin="4,0,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Button x:Name="BulletAnchorButton"
                                        Style="{StaticResource MemoIconButton}"
                                        Foreground="{StaticResource MemoToolbarIconBrush}"
                                        ToolTip="클릭: 가울점(·) — 마우스를 올리면 다른 기호를 고를 수 있어요"
                                        Click="BulletAnchorButton_Click"
                                        MouseEnter="BulletAnchorButton_MouseEnter"
                                        MouseLeave="BulletAnchorButton_MouseLeave">
                                <Viewbox Width="22"
                                             Height="22"
                                             Stretch="Uniform">
                                    <Canvas Width="20"
                                                Height="18"
                                                SnapsToDevicePixels="True">
                                        <Ellipse Canvas.Left="2"
                                                     Canvas.Top="3"
                                                     Width="2.2"
                                                     Height="2.2"
                                                     Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Rectangle Canvas.Left="6.5"
                                                       Canvas.Top="3.6"
                                                       Width="11"
                                                       Height="1.15"
                                                       Fill="{StaticResource MemoToolbarIconBrush}"
                                                       RadiusX="0.5"
                                                       RadiusY="0.5"/>
                                        <Ellipse Canvas.Left="2"
                                                     Canvas.Top="8"
                                                     Width="2.2"
                                                     Height="2.2"
                                                     Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Rectangle Canvas.Left="6.5"
                                                       Canvas.Top="8.6"
                                                       Width="11"
                                                       Height="1.15"
                                                       Fill="{StaticResource MemoToolbarIconBrush}"
                                                       RadiusX="0.5"
                                                       RadiusY="0.5"/>
                                        <Ellipse Canvas.Left="2"
                                                     Canvas.Top="13"
                                                     Width="2.2"
                                                     Height="2.2"
                                                     Fill="{StaticResource MemoToolbarIconBrush}"/>
                                        <Rectangle Canvas.Left="6.5"
                                                       Canvas.Top="13.6"
                                                       Width="11"
                                                       Height="1.15"
                                                       Fill="{StaticResource MemoToolbarIconBrush}"
                                                       RadiusX="0.5"
                                                       RadiusY="0.5"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="BulletStylesPopup"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=BulletAnchorButton}"
                                       AllowsTransparency="True"
                                       StaysOpen="True"
                                       PopupAnimation="Fade">
                                <Border x:Name="BulletPopupContent"
                                            Padding="4,2,2,4"
                                            CornerRadius="8"
                                            BorderBrush="{StaticResource MemoFlyoutPanelBorderBrush}"
                                            BorderThickness="1.2"
                                            Background="{StaticResource MemoFlyoutPanelBrush}"
                                            MouseEnter="BulletPopupContent_MouseEnter"
                                            MouseLeave="BulletPopupContent_MouseLeave">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16"
                                                              ShadowDepth="3"
                                                              Direction="270"
                                                              Opacity="0.28"
                                                              Color="#FF203028"/>
                                    </Border.Effect>
                                    <StackPanel MinWidth="176">
                                        <TextBlock Text="글머리 기호"
                                                       FontSize="10.5"
                                                       Foreground="{StaticResource MemoTextBrush}"
                                                       Opacity="0.8"
                                                       Margin="8,4,4,2"
                                                       FontWeight="SemiBold"
                                                       FontFamily="Segoe UI"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="· " Content="  ·  가울점"
                                                    Click="InsertBulletWithTag_Click"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="• " Content="  •  원형"
                                                    Click="InsertBulletWithTag_Click"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="◦ " Content="  ◦  둥근 흰 점"
                                                    Click="InsertBulletWithTag_Click"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="▪ " Content="  ▪  작은 사각"
                                                    Click="InsertBulletWithTag_Click"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="‣ " Content="  ‣  삼각(오른쪽)"
                                                    Click="InsertBulletWithTag_Click"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="– " Content="  –  짧은 대시"
                                                    Click="InsertBulletWithTag_Click"/>
                                        <Button Style="{StaticResource MemoPopupListButton}"
                                                    Padding="10,4"
                                                    FontFamily="Segoe UI" FontSize="14"
                                                    Foreground="{StaticResource MemoTextBrush}"
                                                    Tag="1. " Content="  1.  번호(시작 1.)"
                                                    Click="InsertBulletWithTag_Click"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <Button Style="{StaticResource MemoIconButton}"
                                Grid.Column="12"
                                Margin="4,0,0,0"
                                HorizontalAlignment="Center"
                                ToolTip="이미지 삽입 — 파일 선택(또는 이미지 파일을 본문으로 드래그)"
                                Foreground="{StaticResource MemoToolbarIconBrush}"
                                Click="InsertImageFromFile_Click">
                            <Viewbox Width="22"
                                         Height="22"
                                         Stretch="Uniform">
                                <Canvas Width="20"
                                            Height="20"
                                            SnapsToDevicePixels="True">
                                    <Rectangle Canvas.Left="2"
                                                   Canvas.Top="2"
                                                   Width="16"
                                                   Height="16"
                                                   RadiusX="3"
                                                   RadiusY="3"
                                                   Stroke="{StaticResource MemoToolbarIconBrush}"
                                                   StrokeThickness="1"
                                                   Fill="Transparent"/>
                                    <Ellipse Canvas.Left="13.5"
                                                 Canvas.Top="4"
                                                 Width="2.4"
                                                 Height="2.4"
                                                 Fill="{StaticResource MemoToolbarIconBrush}"/>
                                    <Path Stroke="{StaticResource MemoToolbarIconBrush}"
                                              StrokeThickness="1"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 5,15.5 L 7.5,10 L 10,12.5 L 12.5,8 L 15,15.5"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Slider Style="{StaticResource MemoFooterSlider}"
                                Grid.Column="13"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0"
                                Width="100"
                                HorizontalAlignment="Left"
                                ToolTip="창 불투명도 · 왼쪽(투명에 가깝게) ↔ 오른쪽(완전 불투명)"
                                Value="{Binding ElementName=RootWindow, Path=Opacity, Mode=TwoWay}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
