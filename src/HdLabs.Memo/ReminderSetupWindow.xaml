<Window x:Class="HdLabs.Memo.ReminderSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="알림 · 미리 알림"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock TextWrapping="Wrap"
                   Foreground="#CCFFFFFF"
                   Text="지정한 시각이 되면(앱이 켜져 있을 때) 약 1초 안에 점검하며, 메인 창을 앞으로 가져온 뒤 소리와 함께 메시지 상자로 알려 줍니다. 앱이 완전히 종료돼 있으면 알리지 않습니다."/>

        <CheckBox x:Name="UseReminderCheck"
                  Margin="0,12,0,8"
                  Foreground="#CCFFFFFF"
                  Content="미리 알림 사용"
                  Checked="UseReminderCheck_OnChanged"
                  Unchecked="UseReminderCheck_OnChanged"/>

        <DatePicker x:Name="DatePick"
                    Margin="0,0,0,8"
                    FontSize="14"/>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <TextBlock Text="시간 (24시:분)" VerticalAlignment="Center" Width="100" Foreground="#CCFFFFFF"/>
            <TextBox x:Name="TimeText"
                     Width="120"
                     Text="12:00"
                     Padding="8,4"/>
        </StackPanel>

        <TextBlock x:Name="HintText"
                   TextWrapping="Wrap"
                   Foreground="#8FCCCC"
                   FontSize="12"
                   Margin="0,0,0,10"
                   Text="형식: HH:mm (예: 09:30, 18:45)"/>

        <TextBlock Text="최근 설정 (최대 5)"
                   Foreground="#CCFFFFFF"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>
        <ListBox x:Name="HistoryList"
                 MaxHeight="124"
                 Margin="0,0,0,12"
                 SelectionChanged="HistoryList_OnSelectionChanged"
                 BorderBrush="#559BB5AA"
                 BorderThickness="1"
                 Background="#26FFFFFF"
                 Foreground="#263330">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Label}" Padding="2,3"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Foreground="#8FCCCC" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="체크를 끄면 알림이 꺼집니다. 최근 설정을 클릭하면 '미리 알림 사용'이 켜지고 날짜·시간이 맞춰집니다."/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="알림 끄고 닫기"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    Click="Clear_Click"
                    ToolTip="알림을 끄고 바로 닫습니다. (체크를 해제한 뒤 '확인'과 같습니다)"/>
            <Button Content="확인"
                    Padding="12,8"
                    IsDefault="True"
                    Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
