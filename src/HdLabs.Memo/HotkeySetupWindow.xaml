<Window x:Class="HdLabs.Memo.HotkeySetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키 설정"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">
    <StackPanel Margin="16">
        <TextBlock TextWrapping="Wrap"
                   Foreground="#CCFFFFFF"
                   Text="창을 앞으로 가져오는 전역 단축키를 설정합니다. 이 창에서 원하는 키 조합을 누르세요. (예: Ctrl+Alt+M)"/>

        <Border Margin="0,14,0,10"
                CornerRadius="10"
                BorderBrush="#559BB5AA"
                BorderThickness="1"
                Background="#26FFFFFF"
                Padding="12,10">
            <StackPanel>
                <TextBlock Text="현재 단축키" Foreground="#8FCCCC" FontSize="12"/>
                <TextBlock x:Name="CurrentHotkeyText"
                           Margin="0,6,0,0"
                           Foreground="#263330"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="HintText"
                           Margin="0,8,0,0"
                           Foreground="#4A6358"
                           FontSize="12"
                           Text="Ctrl/Alt/Shift/Win + 키 조합을 누르세요. (Esc: 취소)"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="기본값으로"
                    Padding="12,8"
                    Margin="0,0,8,0"
                    Click="Reset_Click"/>
            <Button Content="닫기"
                    Padding="12,8"
                    IsDefault="True"
                    Click="Close_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

